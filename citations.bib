@article{krosnick,
    author = {Krosnick, Jon A.},
    title = {Response strategies for coping with the cognitive demands of attitude measures in surveys},
    journal = {Applied Cognitive Psychology},
    volume = {5},
    number = {3},
    pages = {213-236},
    doi = {https://doi.org/10.1002/acp.2350050305},
    url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/acp.2350050305},
    eprint = {https://onlinelibrary.wiley.com/doi/pdf/10.1002/acp.2350050305},
    abstract = {Abstract This paper proposes that when optimally answering a survey question would require substantial cognitive effort, some repondents simply provide a satisfactory answer instead. This behaviour, called satisficing, can take the form of either (1) incomplete or biased information retrieval and/or information integration, or (2) no information retrieval or integration at all. Satisficing may lead respondents to employ a variety of response strategies, including choosing the first response alternative that seems to constitute a reasonable answer, agreeing with an assertion made by a question, endorsing the status quo instead of endorsing social change, failing to differentiate among a set of diverse objects in ratings, saying ‘don't know’ instead of reporting an opinion, and randomly choosing among the response alternatives offered. This paper specifies a wide range of factors that are likely to encourage satisficing, and reviews relevant evidence evaluating these speculations. Many useful directions for future research are suggested.},
    year = {1991}
}

@inbook{beatty,
    author = {Beatty, Paul},
    publisher = {John Wiley & Sons, Ltd},
    isbn = {9781119263685},
    title = {Questionnaire Design, Development, Evaluation, and Testing: Where Are We, and Where Are We Headed?},
    booktitle = {Advances in Questionnaire Design, Development, Evaluation and Testing},
    chapter = {1},
    pages = {1-23},
    doi = {https://doi.org/10.1002/9781119263685.ch1},
    url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/9781119263685.ch1},
    eprint = {https://onlinelibrary.wiley.com/doi/pdf/10.1002/9781119263685.ch1},
    year = {2020},
    keywords = {cognitive interviewing, questionnaire design, Cognitive Aspects of Survey Methodology (CASM), QDET, pretesting, social media, survey response, web probing},
    abstract = {Summary Questionnaire design, development, evaluation, and testing (QDET) has been embedded within the history of social surveys generally, over a span exceeding half a century. Over that time, attempts to focus on the quality of the questionnaire – as a scientific enterprise – have largely been associated with the notion of the Cognitive Aspects of Survey Methodology (CASM), which promotes the interdiscipline between psychology and survey methods. More recent conceptual and theoretical developments have engaged a wider range of disciplines, including linguistics, sociology, and anthropology. The methods associated with QDET that have in turn emerged have varied with respect to their reliance on empirical testing, versus reference to established rules of design and practice. Currently, there is no single commonly accepted approach, and conferences such as QDET2 are devoted to furthering the development and evaluation of procedural alternatives. In order to set the stage for the full set of chapters contained within this volume, the initial chapter explores the landscape of QDET, and considers its place within the current world of survey methods. In conclusion, this chapter makes the case that survey questionnaires (“Q sources”) will continue to have a vital role for data collection, although this role will increasingly be shared with other data sources (“non-Q sources”), perhaps including sensor/observational methods, social media, and “big data.” Further, however, because the direction of future information collection is difficult to predict, it is vital that QDET researchers track ongoing developments, and rapidly and flexibly develop novel methods in response.}
}

@article{haziza,
    ISSN = {08834237, 21688745},
    URL = {http://www.jstor.org/stable/26408226},
    abstract = {Weighting is one of the central steps in surveys. The typical weighting process involves three major stages. At the first stage, each unit is assigned a base weight, which is defined as the inverse of its inclusion probability. The base weights are then modified to account for unit nonresponse. At the last stage, the nonresponse-adjusted weights are further modified to ensure consistency between survey estimates and known population totals. When needed, the weights undergo a last modification through weight trimming or weight smoothing methods in order to improve the efficiency of survey estimates. This article provides an overview of the various stages involved in the typical weighting process used by national statistical offices.},
    author = {David Haziza and Jean-François Beaumont},
    journal = {Statistical Science},
    number = {2},
    pages = {206--226},
    publisher = {Institute of Mathematical Statistics},
    title = {Construction of Weights in Surveys: A Review},
    urldate = {2026-04-12},
    volume = {32},
    year = {2017}
}

